# TDE Demo — Environment Variables

# REQUIRED
OPENROUTER_API_KEY=

# OPTIONAL — defaults to anthropic/claude-sonnet-4.5
OPENROUTER_MODEL_ID=anthropic/claude-sonnet-4.5

# OPTIONAL — Railway sets this automatically
PORT=3000

# OPTIONAL — If set, /api/handoff/leadhydration will POST to
# <LEADHYDRATION_URL>/api/hydrate-one. If unset (or the call fails),
# the demo returns a realistic simulated response so the button always works.
LEADHYDRATION_URL=
LEADHYDRATION_API_KEY=

# OPTIONAL — when set, fetches use Firecrawl (renders JS, returns clean
# markdown). Without it, fetches fall back to basic HTTP and many SPAs return
# empty content.
FIRECRAWL_API_KEY=

# OPTIONAL — when set, the demo runs Apollo people-search after strategies
# are generated to put a real decision-maker (name + title + email) behind the
# AI-identified target_persona of the top-pick strategy.
APOLLO_API_KEY=
